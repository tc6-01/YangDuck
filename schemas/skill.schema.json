{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill/Command/Rule Recipe",
  "type": "object",
  "required": ["id", "name", "type", "description", "files"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["skill", "command", "rule"] },
    "description": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "dest"],
        "properties": {
          "source": { "type": "string" },
          "dest": { "type": "string" }
        }
      }
    },
    "quickstart": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "explain"],
        "properties": {
          "title": { "type": "string" },
          "command": { "type": "string" },
          "explain": { "type": "string" }
        }
      }
    }
  }
}
